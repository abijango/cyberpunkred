// Weapon catalog — Cyberpunk RED.
//
// Sources:
//   pp.170–171  ranged weapon table
//   p.172       Single Shot DVs Based on Range
//   p.173       Autofire DVs Based on Range
//   p.174       alt-fire feature flavour (Arrows, Suppressive Fire,
//               Shotgun Shells, Explosives)
//   pp.175–176  melee weapon table + resolution rules
//   pp.340–344  Night Market appendix (same tables, plus brand examples
//               and the Clip Chart)
//
// Schema (see catalog::weapons::Weapon):
//   slug          string                 // catalog key, also WeaponId.0
//   id            WeaponId(string)       // newtype, must equal slug
//   display_name  string
//   kind          WeaponKind             // Ranged(_) / Melee(_) / Thrown / ExoticRanged / ExoticMelee
//   skill         SkillId
//   damage        DamageDice (n, die)
//   rof           u8                     // 1 or 2
//   hands         u8                     // 1 or 2
//   concealable   bool                   // pp.171, 175 "Can be Concealed?"
//   price         PriceTier              // pp.171, 175 cost column
//   price_eb      Eurobucks              // canonical_cost of the tier
//   features      [WeaponFeature]        // alt-fire modes & special features
//   magazine      Option<Magazine>       // None for melee/thrown/no-magazine exotic
//   ranges        RangeBand              // empty for melee/thrown
//
// Range bands encode (max_meters_inclusive, dv) tuples in ascending range
// order, exactly as printed in the columns on pp.172–173. A weapon with
// "N/A" in a band omits that band (the loader treats out-of-range as None).
//
// Brand examples on p.342 are *flavour*; this catalog stays at the generic
// type level — there is no "federated_arms_x9mm" entry, just "medium_pistol".
WeaponsFile(
    weapons: [
        // ====================================================================
        // RANGED — p.171
        // ====================================================================

        // -- Medium Pistol — p.171 --
        (
            slug: "medium_pistol",
            id: WeaponId("medium_pistol"),
            display_name: "Medium Pistol",
            kind: Ranged(MediumPistol),
            skill: Handgun,
            damage: (n: 2, die: D6),
            rof: 2,
            hands: 1,
            concealable: true,
            price: Costly,
            price_eb: (50),
            features: [],
            magazine: Some((capacity: 12, ammo: MPistol)),
            ranges: (
                single_shot: [(6, 13), (12, 15), (25, 20), (50, 25), (100, 30), (200, 30)],
                autofire: None,
            ),
        ),
        // -- Heavy Pistol — p.171 --
        (
            slug: "heavy_pistol",
            id: WeaponId("heavy_pistol"),
            display_name: "Heavy Pistol",
            kind: Ranged(HeavyPistol),
            skill: Handgun,
            damage: (n: 3, die: D6),
            rof: 2,
            hands: 1,
            concealable: true,
            price: Premium,
            price_eb: (100),
            features: [],
            magazine: Some((capacity: 8, ammo: HPistol)),
            // Pistol row, p.172.
            ranges: (
                single_shot: [(6, 13), (12, 15), (25, 20), (50, 25), (100, 30), (200, 30)],
                autofire: None,
            ),
        ),
        // -- Very Heavy Pistol — p.171 --
        (
            slug: "very_heavy_pistol",
            id: WeaponId("very_heavy_pistol"),
            display_name: "Very Heavy Pistol",
            kind: Ranged(VeryHeavyPistol),
            skill: Handgun,
            damage: (n: 4, die: D6),
            rof: 1,
            hands: 1,
            concealable: false,
            price: Premium,
            price_eb: (100),
            features: [],
            magazine: Some((capacity: 8, ammo: VHPistol)),
            // Pistol row, p.172.
            ranges: (
                single_shot: [(6, 13), (12, 15), (25, 20), (50, 25), (100, 30), (200, 30)],
                autofire: None,
            ),
        ),
        // -- SMG — p.171 (Autofire(3), Suppressive Fire) --
        (
            slug: "smg",
            id: WeaponId("smg"),
            display_name: "SMG",
            kind: Ranged(SMG),
            skill: Handgun,
            damage: (n: 2, die: D6),
            rof: 1,
            hands: 1,
            concealable: true,
            price: Premium,
            price_eb: (100),
            features: [Autofire(3), SuppressiveFire],
            magazine: Some((capacity: 30, ammo: MPistol)),
            // SMG row, p.172, plus SMG autofire row, p.173.
            ranges: (
                single_shot: [(6, 15), (12, 13), (25, 15), (50, 20), (100, 25), (200, 25), (400, 30)],
                autofire: Some([(6, 20), (12, 17), (25, 20), (50, 25), (100, 30)]),
            ),
        ),
        // -- Heavy SMG — p.171 (Autofire(3), Suppressive Fire) --
        // Per p.171 the Heavy SMG fires Heavy Pistol rounds (the H Pistol
        // ammunition entry in the Standard Magazine column). p.172 doesn't
        // print a separate Heavy SMG row, so it inherits the Pistol row
        // for single-shot range bands. The SMG autofire row covers it on
        // p.173 (the column header is "SMGs", plural).
        (
            slug: "heavy_smg",
            id: WeaponId("heavy_smg"),
            display_name: "Heavy SMG",
            kind: Ranged(HeavySMG),
            skill: Handgun,
            damage: (n: 3, die: D6),
            rof: 1,
            hands: 1,
            concealable: false,
            price: Premium,
            price_eb: (100),
            features: [Autofire(3), SuppressiveFire],
            magazine: Some((capacity: 40, ammo: HPistol)),
            ranges: (
                single_shot: [(6, 13), (12, 15), (25, 20), (50, 25), (100, 30), (200, 30)],
                autofire: Some([(6, 20), (12, 17), (25, 20), (50, 25), (100, 30)]),
            ),
        ),
        // -- Shotgun — p.171 (Shotgun Shell alt-fire) --
        (
            slug: "shotgun",
            id: WeaponId("shotgun"),
            display_name: "Shotgun",
            kind: Ranged(Shotgun),
            skill: ShoulderArms,
            damage: (n: 5, die: D6),
            rof: 1,
            hands: 2,
            concealable: false,
            price: Expensive,
            price_eb: (500),
            features: [ShotgunShell],
            magazine: Some((capacity: 4, ammo: Slug)),
            // Shotgun (Slug) row, p.172.
            ranges: (
                single_shot: [(6, 13), (12, 15), (25, 20), (50, 25), (100, 30), (200, 35)],
                autofire: None,
            ),
        ),
        // -- Assault Rifle — p.171 (Autofire(4), Suppressive Fire) --
        (
