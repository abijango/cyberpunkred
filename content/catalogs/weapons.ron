            display_name: "Assault Rifle",
            kind: Ranged(AssaultRifle),
            skill: ShoulderArms,
            damage: (n: 5, die: D6),
            rof: 1,
            hands: 2,
            concealable: false,
            price: Expensive,
            price_eb: (500),
            features: [Autofire(4), SuppressiveFire],
            magazine: Some((capacity: 25, ammo: Rifle)),
            // Assault Rifle row, p.172, plus Assault Rifle autofire row, p.173.
            ranges: (
                single_shot: [(6, 17), (12, 16), (25, 15), (50, 13), (100, 15), (200, 20), (400, 25), (800, 30)],
                autofire: Some([(6, 22), (12, 20), (25, 17), (50, 20), (100, 25)]),
            ),
        ),
        // -- Sniper Rifle — p.171 --
        // Note the inverted curve on p.172: short range is *harder*.
        (
            slug: "sniper_rifle",
            id: WeaponId("sniper_rifle"),
            display_name: "Sniper Rifle",
            kind: Ranged(SniperRifle),
            skill: ShoulderArms,
            damage: (n: 5, die: D6),
            rof: 1,
            hands: 2,
            concealable: false,
            price: Expensive,
            price_eb: (500),
            features: [],
            magazine: Some((capacity: 4, ammo: Rifle)),
            // Sniper Rifle row, p.172.
            ranges: (
                single_shot: [(6, 30), (12, 25), (25, 25), (50, 20), (100, 15), (200, 16), (400, 17), (800, 20)],
                autofire: None,
            ),
        ),
        // -- Bows & Crossbows — p.171 (Arrows feature) --
        // p.171 prints "N/A (Arrow)" in the Standard Magazine column —
        // because (per p.174) basic arrows can always be retrieved, so
        // bows never need to Reload. We encode this as a magazine of
        // capacity 0 with ammo Arrow plus the Arrows feature, and add
        // SilentNotSilenced from the same flavour box.
        (
            slug: "bow_crossbow",
            id: WeaponId("bow_crossbow"),
            display_name: "Bows & Crossbows",
            kind: Ranged(BowCrossbow),
            skill: Archery,
            damage: (n: 4, die: D6),
            rof: 1,
            hands: 2,
            concealable: false,
            price: Premium,
            price_eb: (100),
            features: [Arrows, SilentNotSilenced],
            magazine: Some((capacity: 0, ammo: Arrow)),
            // Bows & Crossbow row, p.172.
            ranges: (
                single_shot: [(6, 15), (12, 13), (25, 15), (50, 17), (100, 20), (200, 22)],
                autofire: None,
            ),
        ),
        // -- Grenade Launcher — p.171 (Explosive) --
        (
