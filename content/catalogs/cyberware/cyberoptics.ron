            price_eb: 100,
            option_slots: 0,
            slot_cost: 1,
            prerequisite_slug: Some("cybereye"),
            effects: [],
            description: "Cybereye Option. Projects a tiny subscreen into user's normal field of vision for messages, video, etc. from a user's other cyberware or electronics. Picture in a picture for real life. Requires a Cybereye. See p.360.",
        ),
        (
            slug: "color_shift",
            display_name: "Color Shift",
            category: Cyberoptics,
            install_difficulty: Mall,
