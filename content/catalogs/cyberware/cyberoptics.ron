            slug: "cybereye_dartgun",
            display_name: "Dartgun",
            category: Cyberoptics,
            install_difficulty: Clinic,
            humanity_loss: Rolled(fixed: 2, dice: (n: 1, die: D6, divisor: 2)),
            price: Expensive,
            price_eb: 500,
            option_slots: 0,
            slot_cost: 3,
            prerequisite_slug: Some("cybereye"),
            effects: [],
            description: "Cybereye Option. Dartgun Exotic Weapon, with only a single shot in the clip, concealed inside the Cybereye. Requires a Cybereye and takes 3 Option Slots. See p.360.",
        ),
        (
