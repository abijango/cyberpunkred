// Cyberoptics (rulebook p.112 abbreviated, p.360-361 detailed).
//
// Foundational cyberware: Cybereye (3 Option Slots per eye). Some options
// must be paired (purchased twice and installed into two different
// Cybereyes); HL is calculated separately for each purchase (p.360).
// We catalog one row per item: the runtime install pipeline handles
// pairing.
CyberwareFile(
    cyberware: [
        // -- Foundational --
        (
            slug: "cybereye",
            display_name: "Cybereye",
            category: Cyberoptics,
            install_difficulty: Clinic,
            humanity_loss: Rolled(fixed: 7, dice: (n: 2, die: D6, divisor: 1)),
            price: Premium,
            price_eb: 100,
            option_slots: 3,
            slot_cost: 0,
            prerequisite_slug: None,
            effects: [],
            description: "All following options are installed in an artificial eye that replaces a meat one. Each Cybereye has 3 Option Slots for Cybereye Options. Some options must be paired to work properly (purchased twice and installed into two different Cybereyes on a user). Humanity Loss is calculated separately for each purchase. See p.360.",
        ),

        // -- Cybereye options --
        (
            slug: "anti_dazzle",
            display_name: "Anti-Dazzle",
            category: Cyberoptics,
            install_difficulty: Mall,
            humanity_loss: Rolled(fixed: 2, dice: (n: 1, die: D6, divisor: 2)),
            price: Premium,
            price_eb: 100,
            option_slots: 0,
            slot_cost: 1,
            prerequisite_slug: Some("cybereye"),
            effects: [],
            description: "Cybereye Option. User is immune to blindness or other effects caused by dangerous flashes of light, like those of a flashbang. Requires two Cybereyes and must be paired. See p.360.",
        ),
        (
            slug: "chyron",
