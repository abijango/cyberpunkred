            price: Premium,
            price_eb: 100,
            option_slots: 0,
            slot_cost: 1,
            prerequisite_slug: Some("cybereye"),
            effects: [],
            description: "Cybereye Option. Cosmetic upgrade allows unlimited color and pattern changes to be made as an Action. Eye can optionally be temperature sensitive or reactant to hormone changes in the body. Requires a Cybereye. See p.360.",
        ),
